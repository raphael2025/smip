# 新加坡服务器 Docker 内使用：主机名填 postgres / redis
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=smip
DATABASE_USER=smip_user
DATABASE_PASSWORD=请设置强密码

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=请设置Redis密码

# 可选：Binance 合约 API（部分数据需密钥）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 可选：OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
